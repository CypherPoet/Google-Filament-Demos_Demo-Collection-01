# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'FilamentDemoLab' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # React Native 0.83 vendors fmt 11, which selects its `consteval`
    # format-string path whenever the compiler advertises __cpp_consteval. The
    # clang in Xcode 26 advertises it but then rejects fmt's usage with "call to
    # consteval function ... is not a constant expression". fmt's base.h #defines
    # FMT_USE_CONSTEVAL unconditionally (no #ifndef guard), so a -D override is
    # clobbered — we have to patch the copied header to pin it to fmt's constexpr
    # fallback. Re-applied on every `pod install`, so the repo stays buildable.
    fmt_base = File.join(Pod::Config.instance.installation_root.to_s, 'Pods', 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      original = File.read(fmt_base)
      patched = original.gsub('#  define FMT_USE_CONSTEVAL 1', '#  define FMT_USE_CONSTEVAL 0')
      if patched != original
        # CocoaPods copies fmt's headers as read-only (0444); make it writable first.
        File.chmod(0o644, fmt_base)
        File.write(fmt_base, patched)
        Pod::UI.puts '[FilamentDemoLab] Patched fmt/base.h: FMT_USE_CONSTEVAL -> 0 (Xcode 26 clang fix)'
      end
    end
  end
end
